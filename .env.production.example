# Vercel Environment Variables
# Copy these to Vercel Dashboard > Settings > Environment Variables

# Supabase Configuration
# Get these values from your Supabase project dashboard
# https://supabase.com/dashboard/project/YOUR_PROJECT_ID/settings/api

# Example for project: mauyygrbdopmpdpnwzra
# VITE_SUPABASE_URL=https://mauyygrbdopmpdpnwzra.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_key_here

VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# IMPORTANT: 
# 1. Never commit actual credentials to git
# 2. Keep your .env file in .gitignore
# 3. Rotate keys immediately if exposed
# 4. Enable Row Level Security (RLS) on all tables
# 5. Only use anon key in client-side code
# 6. Never expose service_role key to client
